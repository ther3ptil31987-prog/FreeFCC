# Copy to edgehatch/keystore.properties (git-ignored) to sign the release build.
# Never commit the real file or the .jks keystore.
# Alternatively set EDGEHATCH_STORE_FILE / EDGEHATCH_STORE_PASSWORD /
# EDGEHATCH_KEY_ALIAS / EDGEHATCH_KEY_PASSWORD in the environment.
storeFile=/absolute/path/to/edgehatch-release.jks
storePassword=changeit
keyAlias=edgehatch
keyPassword=changeit
