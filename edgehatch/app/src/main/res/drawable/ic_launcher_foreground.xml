<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- EdgeHatch mark: a rounded edge handle at the screen edge, and a hatch
         panel opening toward it (an outlined rounded rect left open on the
         handle side). Brand green on the adaptive slate background; same palette
         and contrast as the app theme (ui-ux-pro-max design system). -->
    <group android:translateX="0" android:translateY="0">
        <!-- edge handle bar -->
        <path
            android:fillColor="#4ADE80"
            android:pathData="M30,38 h6 a4,4 0 0 1 4,4 v24 a4,4 0 0 1 -4,4 h-6 a4,4 0 0 1 -4,-4 v-24 a4,4 0 0 1 4,-4 z" />
        <!-- hatch panel, opening toward the handle (no left edge) -->
        <path
            android:strokeColor="#4ADE80"
            android:strokeWidth="5"
            android:strokeLineJoin="round"
            android:strokeLineCap="round"
            android:fillColor="#00000000"
            android:pathData="M52,41 h22 a4,4 0 0 1 4,4 v18 a4,4 0 0 1 -4,4 h-22" />
    </group>
</vector>
