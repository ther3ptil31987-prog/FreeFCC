<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Single DayNight theme; colors auto-switch via values-night/. -->
    <style name="Theme.EdgeHatch" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_green</item>
        <item name="colorOnPrimary">@color/brand_green_on</item>
        <item name="colorSecondary">@color/brand_green</item>
        <item name="colorOnSecondary">@color/brand_green_on</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceContainer">@color/surface_container</item>
        <item name="colorSurfaceContainerHigh">@color/surface_container</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_muted</item>
        <item name="colorOutline">@color/outline</item>
        <item name="colorError">@color/destructive</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
    </style>
</resources>
