<?xml version="1.0" encoding="utf-8"?>
<!-- Inflated into EdgePanelView (a FrameLayout). The scrim fills the screen and
     dismisses on tap; the card is anchored to the triggering edge in code. -->
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <View
        android:id="@+id/scrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/scrim" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/panel_card"
        android:layout_width="@dimen/panel_card_width"
        android:layout_height="wrap_content"
        android:layout_gravity="end|center_vertical"
        android:layout_margin="@dimen/panel_card_margin"
        app:cardBackgroundColor="?attr/colorSurface"
        app:cardCornerRadius="@dimen/panel_corner"
        app:cardElevation="8dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/panel_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="8dp"
                android:clipToPadding="false" />

            <TextView
                android:id="@+id/empty_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp"
                android:gravity="center"
                android:text="@string/panel_empty"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:visibility="gone" />
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>
</merge>
